# --- LLM provider ---
# One of: groq, anthropic, openai
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.0

# Only the key for your chosen provider is required.
GROQ_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Embeddings ---
# Local model, no API key needed. Override to swap models.
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Ingestion limits ---
MAX_DOCUMENT_CHARS=100000
CHUNK_SIZE=1000
CHUNK_OVERLAP=150

# --- Retrieval ---
RETRIEVAL_K=4

# --- Observability ---
# Leave LANGSMITH_TRACING=false to use built-in callback logging only.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=doc-qa-agent
